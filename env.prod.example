# Archivo de ejemplo para las variables de entorno en producción (.env.prod)
# ¡NO DEBES SUBIR ESTE ARCHIVO AL CONTROL DE VERSIONES CON VALORES REALES!
# Crea un archivo .env.prod real y añade este al .gitignore.

# --- Configuración de la Base de Datos (Amazon RDS PostgreSQL) ---
# Sustituye 'tu_endpoint_rds', 'tu_puerto_rds', 'tu_usuario_rds', 'tu_contraseña_rds', 'nombre_tu_db_rds'
DATABASE_URL="postgresql://tu_usuario_rds:tu_contraseña_rds@tu_endpoint_rds:tu_puerto_rds/nombre_tu_db_rds"

# --- Configuración de Redis (Amazon ElastiCache) ---
# Sustituye 'tu_endpoint_elasticache' por el endpoint primario de tu clúster ElastiCache
REDIS_HOST=tu_endpoint_elasticache
REDIS_PORT=6379 # O el puerto que hayas configurado en ElastiCache

# --- Variables de Entorno de la Aplicación ---
# Sustituye por tu secreto JWT real y robusto
JWT_SECRET=tu_jwt_secret_muy_largo_y_seguro

# URL del frontend en producción
FRONTEND_URL=https://tu-dominio-frontend.com

# Puerto en el que la aplicación escuchará (dentro del contenedor)
PORT=4000

# --- Configuración de Email (ej. Brevo o Gmail) ---
# Si usas Brevo (Sendinblue)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=tu_email_brevo
EMAIL_PASS=tu_clave_api_brevo

# Si usas Gmail (requiere "Contraseñas de aplicación" si tienes 2FA)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=tu_email_gmail
# EMAIL_PASS=tu_contraseña_de_aplicacion_gmail

# --- Configuración de S3/R2 (ej. Cloudflare R2 o AWS S3) ---
# R2 (Cloudflare)
R2_ACCESS_KEY_ID=tu_r2_access_key_id
R2_SECRET_ACCESS_KEY=tu_r2_secret_access_key
R2_BUCKET_NAME=tu_r2_bucket_name
R2_ACCOUNT_ID=tu_r2_account_id
R2_ENDPOINT=https://tu_account_id.r2.cloudflarestorage.com # O el endpoint personalizado de tu bucket

# AWS S3
# AWS_S3_ACCESS_KEY_ID=tu_aws_s3_access_key_id
# AWS_S3_SECRET_ACCESS_KEY=tu_aws_s3_secret_access_key
# AWS_S3_BUCKET_NAME=tu_aws_s3_bucket_name
# AWS_S3_REGION=tu_aws_s3_region

# --- Otras variables (si tienes) ---
# NODE_ENV=production
# LOG_LEVEL=info
