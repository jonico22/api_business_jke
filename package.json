{
  "name": "secure-auth-api",
  "version": "1.0.0",
  "scripts": {
    "dev:start": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register --poll src/index.ts",
    "dev:prisma": "npx prisma generate && npx prisma migrate dev --name init",
    "prisma:seed": "npx tsx prisma/seed.ts",
    "dev": "npm run dev:prisma && npm run prisma:seed && npm run dev:start",
    "migrate:deploy": "npx prisma migrate deploy && npm run prisma:seed",
    "build": "node --max-old-space-size=2048 ./node_modules/.bin/tsc && tsc-alias",
    "start:prod-app": "npm run migrate:deploy && node -r tsconfig-paths/register dist/index.js",
    "start:prod": " npm run start:prod-app",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio",
    "docker:dev": "infisical run --env=dev --path=/api -- docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up api db redis --build",
    "docker:clean": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml down -v --remove-orphans"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.844.0",
    "@aws-sdk/s3-request-presigner": "^3.844.0",
    "@getbrevo/brevo": "^3.0.1",
    "@newrelic/winston-enricher": "^4.0.1",
    "@prisma/client": "^6.13.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.1",
    "newrelic": "^13.9.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^7.0.11",
    "pdfmake": "^0.2.20",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.5.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.25",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.1",
    "@types/node-cache": "^4.1.3",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfmake": "^0.2.12",
    "@types/qrcode": "^1.5.5",
    "@types/rate-limit-redis": "^1.7.4",
    "@types/redis": "^4.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "dotenv": "^16.5.0",
    "install": "^0.13.0",
    "npm": "^11.7.0",
    "prisma": "^6.13.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
